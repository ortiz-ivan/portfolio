{
	"useTabs": true,
	"singleQuote": true,
	"semi": true,
	"printWidth": 100,
	"trailingComma": "none",
	"plugins": ["prettier-plugin-astro"],
	"overrides": [
		{
			"files": "*.astro",
			"options": { "parser": "astro" }
		},
		{
			"files": "package.json",
			"options": { "useTabs": false, "tabWidth": 2 }
		}
	]
}
