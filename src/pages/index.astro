---
import Layout from '../layouts/Layout.astro';
import '../styles/editorial-home.css';
import { projects } from '../data/projects';
import {
	contactSection,
	experienceSection,
	footerContent,
	heroContent
} from '../data/site';

const hero = heroContent;
const sorted = [...projects].sort((a, b) => a.priority - b.priority);
const featured = sorted.find((p) => p.isFeatured) ?? sorted[0];
const rest = sorted.filter((p) => p !== featured);
const heroStack = experienceSection.items[0]?.tech ?? [
	'Java',
	'Spring',
	'PostgreSQL',
	'Angular',
	'React'
];

// pick a primary link for a project (case-study > first available > first)
const primaryLink = (p: (typeof projects)[number]) =>
	p.links.find((l) => l.kind === 'case-study' && l.available) ??
	p.links.find((l) => l.available) ??
	p.links.find((l) => l.kind === 'case-study') ??
	p.links[0];

const cover = (p: (typeof projects)[number]) =>
	p.images.find((i) => i.role === 'cover') ?? p.images[0];

const navItems = [
	{ id: 'sobre-mi', label: 'Sobre mí' },
	{ id: 'projects', label: 'Proyectos' },
	{ id: 'experience', label: 'Experiencia' },
	{ id: 'contact', label: 'Contacto' }
];
---

<Layout
	title="Iván Ortiz — Fullstack Developer"
	description="Iván Ortiz, desarrollador fullstack enfocado en backend, integraciones y sistemas de gestión claros y mantenibles."
>
	<main class="ed-home" id="top">
		<!-- ============ NAV ============ -->
		<header class="nav" id="nav">
			<div class="wrap nav-inner">
				<a class="brand" href="#top" aria-label="Inicio">
					<span class="mark">
						<img src="/logo_final.png" alt="Iván Ortiz" width="26" height="26" />
					</span>
					<span>{hero.name}</span>
				</a>
				<nav class="nav-links" id="navLinks" aria-label="Navegación principal">
					{navItems.map((item, i) => (
						<a class="nav-link" href={`#${item.id}`}>
							<span class="idx">{String(i + 1).padStart(2, '0')}</span>{item.label}
						</a>
					))}
				</nav>
				<button class="nav-toggle" id="navToggle" aria-label="Abrir menú" aria-expanded="false">
					<span></span><span></span><span></span>
				</button>
			</div>
		</header>

		<!-- ============ HERO / SOBRE MÍ ============ -->
		<section class="ed-hero" id="sobre-mi" data-screen-label="Hero / Sobre mí">
			<div class="wrap">
				<div class="hero-top reveal">
					<span class="ed-eyebrow"><span class="dot"></span>{hero.role}</span>
					<span class="hero-availability">Disponible para oportunidades</span>
				</div>

				<h1 class="hero-title display reveal">
					<span class="line">{hero.name.split(' ')[0]}</span>
					<span class="line"><em>{hero.name.split(' ').slice(1).join(' ')}</em></span>
				</h1>

				<div class="ed-hero-grid">
					<div class="ed-hero-copy reveal">
						<p class="hero-intro">{hero.subtitle}</p>
						<div class="hero-narr-wrap">
							<p class="hero-narrative">{hero.narrative}</p>
							<p class="hero-narrative">{hero.panelSummary}</p>
						</div>

						<div class="cta-row">
							<a class="btn" href={hero.primaryCta.href}>
								{hero.primaryCta.label} <span class="arrow">↗</span>
							</a>
							<a
								class="btn btn-ghost"
								href={hero.secondaryCta.href}
								download={hero.secondaryCta.download}
							>
								{hero.secondaryCta.label} <span class="arrow">↓</span>
							</a>
						</div>
					</div>

					<aside class="hero-meta reveal">
						<div class="meta-row">
							<span class="meta-k">Stack principal</span>
							<div class="tag-row">
								{heroStack.map((t) => <span class="tag">{t}</span>)}
							</div>
						</div>
						<div class="meta-row">
							<span class="meta-k">Enfoque</span>
							<span class="meta-v">Entender la operación antes que el sistema. Decisiones técnicas sostenibles.</span>
						</div>
					</aside>
				</div>
			</div>
		</section>

		<!-- ============ PROYECTOS ============ -->
		<section class="ed-section" id="projects" data-screen-label="Proyectos">
			<div class="wrap">
				<div class="sec-head reveal">
					<span class="sec-num">(02)</span>
					<span class="sec-label">Proyectos seleccionados</span>
					<span class="rule-flex"></span>
				</div>

				<div class="projects-list">
					{featured && (
						<article class="proj-featured reveal">
							<div class="proj-featured-body">
								<span class="proj-index">01 — {featured.eyebrow}</span>
								<h3 class="proj-name">{featured.name}</h3>
								<p class="proj-summary">{featured.summary}</p>
								<div class="proj-tags">
									{featured.tech.map((t) => <span class="tag">{t}</span>)}
								</div>
								<div class="proj-links">
									{featured.links.map((l) =>
										l.available ? (
											<a
												class="tlink"
												href={l.href}
												target={l.href.startsWith('http') ? '_blank' : undefined}
												rel={l.href.startsWith('http') ? 'noopener' : undefined}
											>
												{l.label} <span class="arrow">↗</span>
											</a>
										) : (
											<span class="tlink disabled">{l.label} · pronto</span>
										)
									)}
								</div>
							</div>
							<div class="proj-visual">
								<span class="corner">[ cover ]</span>
								<p class="ph">{cover(featured)?.caption ?? featured.name}</p>
							</div>
						</article>
					)}

					{rest.map((p, i) => {
						const link = primaryLink(p);
						const external = link?.available && link.href.startsWith('http');
						return (
							<article class="proj-row reveal">
								<span class="r-index">{String(i + 2).padStart(2, '0')}</span>
								<span class="r-name">
									{p.name}
									<span class="r-eyebrow">{p.eyebrow}</span>
								</span>
								<div class="r-desc">
									{p.summary}
									<div class="r-tags">
										{p.tech.slice(0, 4).map((t) => <span class="tag">{t}</span>)}
									</div>
								</div>
								<a
									class="r-action"
									href={link?.available ? link.href : '#contact'}
									target={external ? '_blank' : undefined}
									rel={external ? 'noopener' : undefined}
									aria-label={`${p.name} — ${link?.label ?? 'ver más'}`}
								>
									<span class="tlink">{link?.available ? link.label : 'Detalles pronto'}</span>
									<span class="r-arrow">↗</span>
								</a>
							</article>
						);
					})}
				</div>
			</div>
		</section>

		<!-- ============ EXPERIENCIA ============ -->
		<section class="ed-section" id="experience" data-screen-label="Experiencia">
			<div class="wrap">
				<div class="sec-head reveal">
					<span class="sec-num">(03)</span>
					<span class="sec-label">Experiencia</span>
					<span class="rule-flex"></span>
				</div>

				{experienceSection.items.map((item) => (
					<article class="exp-entry reveal">
						<div class="exp-left">
							<h3 class="exp-company">{item.company}</h3>
							<span class="exp-period">{item.period}</span>
							<span class="exp-role">{item.role}</span>
						</div>
						<div class="exp-right">
							<p class="exp-desc">{item.description}</p>
							<ol class="exp-resp">
								{item.responsibilities.map((r) => <li>{r}</li>)}
							</ol>
							<div class="exp-tech">
								{item.tech.map((t) => <span class="tag">{t}</span>)}
							</div>
						</div>
					</article>
				))}
			</div>
		</section>

		<!-- ============ CONTACTO ============ -->
		<section class="contact" id="contact" data-screen-label="Contacto">
			<div class="wrap">
				<div class="sec-head reveal">
					<span class="sec-num">(04)</span>
					<span class="sec-label">Contacto</span>
					<span class="rule-flex"></span>
				</div>

				<h2 class="contact-head display reveal">{contactSection.title}</h2>

				<div class="contact-grid reveal">
					{contactSection.items.map((item) => {
						const isProtected = Boolean(item.protected);
						const external = item.href?.startsWith('http') ?? false;

						if (isProtected && item.protected) {
							return (
								<div class="ed-contact-item">
									<span class="contact-k">{item.label}</span>
									<button
										type="button"
										class="contact-v"
										data-contact-protected
										data-contact-scheme={item.protected.scheme}
										data-contact-parts={item.protected.parts.join('|')}
										data-contact-display={item.protected.displayParts.join('|')}
										aria-label={item.protected.actionLabel}
									>
										<span class="contact-v-label">{item.value}</span> <span class="arrow">↗</span>
									</button>
									<span class="contact-desc">{item.description}</span>
								</div>
							);
						}

						return (
							<div class="ed-contact-item">
								<span class="contact-k">{item.label}</span>
								<a
									class="contact-v"
									href={item.href}
									target={external ? '_blank' : undefined}
									rel={external ? 'noopener' : undefined}
								>
									{item.value} <span class="arrow">↗</span>
								</a>
								<span class="contact-desc">{item.description}</span>
							</div>
						);
					})}
				</div>

				<footer class="footer">
					<p class="footer-copy">{footerContent.copy}</p>
					<div class="footer-meta">
						<a class="footer-top" href="#top">Volver arriba <span class="arrow">↑</span></a>
						<div class="footer-year">© {new Date().getFullYear()} · Diseñado y construido por {hero.name}</div>
					</div>
				</footer>
			</div>
		</section>
	</main>
</Layout>

<script>
	// ---- Nav background on scroll ----
	const nav = document.getElementById('nav');
	const onScroll = () => {
		if (!nav) return;
		nav.classList.toggle('scrolled', window.scrollY > 24);
	};
	window.addEventListener('scroll', onScroll, { passive: true });
	onScroll();

	// ---- Mobile menu ----
	const toggle = document.getElementById('navToggle');
	const links = document.getElementById('navLinks');
	if (toggle && links) {
		toggle.addEventListener('click', () => {
			const open = links.classList.toggle('open');
			toggle.classList.toggle('open', open);
			toggle.setAttribute('aria-expanded', String(open));
		});
		links.querySelectorAll('.nav-link').forEach((a) =>
			a.addEventListener('click', () => {
				links.classList.remove('open');
				toggle.classList.remove('open');
				toggle.setAttribute('aria-expanded', 'false');
			})
		);
	}

	// ---- Scrollspy ----
	const ids = ['sobre-mi', 'projects', 'experience', 'contact'];
	const sections = ids.map((id) => document.getElementById(id)).filter(Boolean) as HTMLElement[];
	const navLinkEls = Array.from(document.querySelectorAll<HTMLAnchorElement>('.nav-link'));
	const spy = new IntersectionObserver(
		(entries) => {
			entries.forEach((e) => {
				if (e.isIntersecting) {
					navLinkEls.forEach((l) =>
						l.classList.toggle('active', l.getAttribute('href') === '#' + e.target.id)
					);
				}
			});
		},
		{ rootMargin: '-45% 0px -50% 0px', threshold: 0 }
	);
	sections.forEach((s) => spy.observe(s));

	// ---- Reveal on scroll ----
	const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
	const revealEls = Array.from(document.querySelectorAll('.reveal'));
	if (reduce) {
		revealEls.forEach((el) => el.classList.add('in'));
	} else {
		const ro = new IntersectionObserver(
			(entries) => {
				entries.forEach((e) => {
					if (e.isIntersecting) {
						e.target.classList.add('in');
						ro.unobserve(e.target);
					}
				});
			},
			{ rootMargin: '0px 0px -10% 0px', threshold: 0.08 }
		);
		revealEls.forEach((el) => ro.observe(el));
	}

	// ---- Protected email (reuse tu lógica: abre Gmail compose) ----
	const decode = (v: string) => v.split('|').join('');
	const openContact = (scheme: string, value: string) => {
		if (scheme === 'mailto') {
			const url = new URL('https://mail.google.com/mail/');
			url.searchParams.set('view', 'cm');
			url.searchParams.set('fs', '1');
			url.searchParams.set('to', value);
			window.open(url.toString(), '_blank', 'noopener,noreferrer');
			return;
		}
		window.location.href = `${scheme}:${value}`;
	};
	document.querySelectorAll<HTMLButtonElement>('[data-contact-protected]').forEach((btn) => {
		const scheme = btn.dataset.contactScheme;
		const parts = btn.dataset.contactParts;
		const display = btn.dataset.contactDisplay;
		const labelNode = btn.querySelector('.contact-v-label');
		if (!scheme || !parts || !display || !labelNode) return;
		const reveal = () => {
			labelNode.textContent = decode(display);
			openContact(scheme, decode(parts));
		};
		btn.addEventListener('click', reveal);
		btn.addEventListener('keydown', (ev) => {
			if (ev.key === 'Enter' || ev.key === ' ') {
				ev.preventDefault();
				reveal();
			}
		});
	});
</script>
