---
import ProjectCard from '../components/ProjectCard.astro';
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects';
import {
	contactSection,
	experienceSection,
	footerContent,
	heroContent,
	projectSection,
	thinkingSection
} from '../data/site';

const featuredProjects = [...projects].sort((left, right) => left.priority - right.priority);
const contactIcons: Record<string, { viewBox: string; path: string }> = {
	linkedin: {
		viewBox: '0 0 24 24',
		path: 'M6.94 8.5H3.56V19h3.38zm.22-3.69C7.16 3.77 6.4 3 5.26 3S3.38 3.77 3.38 4.81s.74 1.81 1.86 1.81h.02c1.16 0 1.9-.77 1.9-1.81M20.62 19h-3.38v-5.62c0-1.41-.5-2.37-1.76-2.37-.96 0-1.53.65-1.78 1.28-.09.22-.11.53-.11.85V19H10.2s.04-9.74 0-10.5h3.39v1.49c.45-.7 1.25-1.7 3.05-1.7 2.23 0 3.9 1.46 3.9 4.59z'
	},
	email: {
		viewBox: '0 0 24 24',
		path: 'M20 5H4a2 2 0 0 0-2 2v.35l10 5.88 10-5.88V7a2 2 0 0 0-2-2m2 4.65-9.5 5.59a1 1 0 0 1-1 0L2 9.65V17a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2z'
	},
	github: {
		viewBox: '0 0 24 24',
		path: 'M12 .5C5.65.5.5 5.66.5 12.02c0 5.08 3.29 9.39 7.86 10.9.57.1.78-.25.78-.56 0-.28-.01-1.19-.02-2.15-3.2.7-3.88-1.36-3.88-1.36-.52-1.34-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.2 1.77 1.2 1.03 1.77 2.7 1.26 3.36.97.1-.75.4-1.26.73-1.55-2.56-.29-5.25-1.28-5.25-5.72 0-1.27.45-2.31 1.2-3.13-.12-.3-.52-1.5.11-3.12 0 0 .98-.32 3.2 1.19a10.9 10.9 0 0 1 5.82 0c2.22-1.51 3.2-1.19 3.2-1.19.63 1.62.23 2.82.11 3.12.75.82 1.2 1.86 1.2 3.13 0 4.45-2.7 5.42-5.27 5.7.41.36.78 1.08.78 2.17 0 1.57-.02 2.83-.02 3.21 0 .31.21.67.79.56a11.53 11.53 0 0 0 7.84-10.9C23.5 5.66 18.35.5 12 .5'
	}
};
---

<Layout
	title="Iván Ortiz | Fullstack Developer"
	description="Portfolio de Iván Ortiz. Desarrollo sistemas de gestión y automatización enfocados en negocios reales."
>
	<main>
		<section class="hero section container" aria-label="Presentación principal">
			<div class="hero-grid">
				<div class="hero-copy">
					<span class="eyebrow">{heroContent.positioning}</span>
					<h1 class="title-display">{heroContent.name}</h1>
					<p class="hero-role">{heroContent.role}</p>
					<p class="lead">
						{heroContent.subtitle}
					</p>
					<p class="body-copy">
						{heroContent.narrative}
					</p>
					<div class="button-row">
						<a class="button" href={heroContent.primaryCta.href}>{heroContent.primaryCta.label}</a>
						<a class="button button-secondary" href={heroContent.secondaryCta.href}
							>{heroContent.secondaryCta.label}</a
						>
					</div>
				</div>

				<aside class="panel hero-panel" aria-label="Dirección del portfolio">
					<div class="stack-list">
						<div class="meta-block">
							<span class="meta-label">Posicionamiento</span>
							<p class="meta-value">Enfocado en sistemas de gestión y automatización de procesos.</p>
						</div>
						<div class="meta-block">
							<span class="meta-label">Stack base</span>
							<ul class="pill-list">
								<li>Python</li>
								<li>Java</li>
								<li>Javascript</li>
								<li>Angular</li>
								<li>Astro</li>
								<li>React</li>
								<li>Tailwind CSS</li>
								<li>PostgreSQL</li>
								<li>Git</li>
								<li>Docker</li>
							</ul>
						</div>
					</div>

					<div class="metric">
						<span class="metric-label">Enfoque</span>
						<span class="metric-value">Negocio + arquitectura</span>
						<p class="muted-note">
							Portfolio orientado a mostrar sistemas reales, criterio tecnico y capacidad para
							traducir procesos en producto.
						</p>
					</div>
				</aside>
			</div>
		</section>

		<section id="projects" class="section container" aria-labelledby="projects-title">
			<span class="section-anchor" aria-hidden="true"></span>
			<div class="section-heading">
				<span class="eyebrow">{projectSection.kicker}</span>
				<h2 id="projects-title" class="title-section">{projectSection.title}</h2>
				<p class="section-copy">
					{projectSection.intro}
				</p>
			</div>

			<div class="card-grid">
				{featuredProjects.map((project) => (
					<ProjectCard project={project} />
				))}
			</div>
		</section>

		<section id="experience" class="section container" aria-labelledby="experience-title">
			<div class="section-heading">
				<span class="eyebrow">{experienceSection.kicker}</span>
				<h2 id="experience-title" class="title-section">{experienceSection.title}</h2>
			</div>

			<div class="experience-grid">
				{experienceSection.items.map((item) => (
					<article class="panel experience-card">
						<div class="experience-header">
							<div>
								<p class="experience-company">{item.company}</p>
								<h3 class="card-title">{item.role}</h3>
							</div>
							<span class="experience-period">{item.period}</span>
						</div>

						<p class="card-copy">{item.description}</p>

						<ul class="compact-list experience-list">
							{item.responsibilities.map((responsibility) => (
								<li>{responsibility}</li>
							))}
						</ul>

						<ul class="pill-list">
							{item.tech.map((tech) => (
								<li>{tech}</li>
							))}
						</ul>
					</article>
				))}
			</div>
		</section>

		<section id="thinking" class="section container" aria-labelledby="thinking-title">
			<div class="section-heading">
				<span class="eyebrow">{thinkingSection.kicker}</span>
				<h2 id="thinking-title" class="title-section">{thinkingSection.title}</h2>
				<p class="section-copy">
					{thinkingSection.intro}
				</p>
			</div>

			<div class="card-grid">
				{thinkingSection.principles.map((principle) => (
					<article class="panel principle-card">
						<h3 class="card-title">{principle.title}</h3>
						<p class="card-copy">{principle.copy}</p>
					</article>
				))}
			</div>
		</section>

		<section id="contact" class="section container" aria-labelledby="contact-title">
			<span class="section-anchor" aria-hidden="true"></span>
			<div class="panel contact-panel">
				<div class="section-heading">
					<span class="eyebrow">{contactSection.kicker}</span>
					<h2 id="contact-title" class="title-section">{contactSection.title}</h2>
					<p class="section-copy">{contactSection.intro}</p>
				</div>

				<div class="contact-list" role="list">
					{contactSection.items.map((item) => {
						const icon = contactIcons[item.label.toLowerCase()];
						const contactKind = item.label.toLowerCase();

						return (
							<a
								class="contact-item"
								data-contact-kind={contactKind}
								href={item.href}
								target="_blank"
								rel="noreferrer"
								role="listitem"
							>
								<div class="contact-item-header">
									<span class="contact-icon">
										{icon && (
											<svg viewBox={icon.viewBox} aria-hidden="true">
												<path fill="currentColor" d={icon.path}></path>
											</svg>
										)}
									</span>
									<span class="contact-label">{item.label}</span>
								</div>
								<strong class="contact-value">{item.value}</strong>
								<span class="muted-note">{item.description}</span>
							</a>
						);
					})}
				</div>
			</div>
		</section>

		<footer class="container site-footer">
			<p class="site-footer-copy">{footerContent.copy}</p>
			<nav aria-label="Navegacion del pie" class="footer-nav">
				{footerContent.links.map((link) => (
					<a href={link.href}>{link.label}</a>
				))}
			</nav>
		</footer>
	</main>
</Layout>
