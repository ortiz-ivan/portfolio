---
import Layout from '../layouts/Layout.astro';
import '../styles/editorial-home.css';
import { getCollection } from 'astro:content';
import { contactSection, experienceSection, footerContent, heroContent } from '../data/site';
import NavBar from '../components/NavBar.astro';
import HeroSection from '../components/HeroSection.astro';
import ProjectsSection from '../components/ProjectsSection.astro';
import ExperienceSection from '../components/ExperienceSection.astro';
import ContactSection from '../components/ContactSection.astro';

const allProjects = await getCollection('projects');
const sorted = [...allProjects].sort((a, b) => a.data.priority - b.data.priority);
const featured = sorted.find((p) => p.data.isFeatured) ?? sorted[0];
const rest = sorted.filter((p) => p !== featured);

const heroStack = experienceSection.items[0]?.tech ?? [
	'Java',
	'Spring',
	'PostgreSQL',
	'Angular',
	'React'
];

const navItems = [
	{ href: '#sobre-mi', label: 'Sobre mí', index: '01' },
	{ href: '#projects', label: 'Proyectos', index: '02' },
	{ href: '#experience', label: 'Experiencia', index: '03' },
	{ href: '#contact', label: 'Contacto', index: '04' }
];
---

<Layout
	title="Iván Ortiz — Fullstack Developer"
	description="Iván Ortiz, desarrollador fullstack enfocado en backend, integraciones y sistemas de gestión claros y mantenibles."
>
	<main class="ed-home" id="top">
		<NavBar name={heroContent.name} items={navItems} />
		<HeroSection hero={heroContent} heroStack={heroStack} />
		<ProjectsSection featured={featured} rest={rest} />
		<ExperienceSection data={experienceSection} />
		<ContactSection data={contactSection} footer={footerContent} authorName={heroContent.name} />
	</main>
</Layout>

<script>
	let spyObserver: IntersectionObserver | null = null;

	function initScrollspy() {
		const ids = ['sobre-mi', 'projects', 'experience', 'contact'];
		const sections = ids.map((id) => document.getElementById(id)).filter(Boolean) as HTMLElement[];
		if (sections.length === 0) return;

		const navLinkEls = Array.from(document.querySelectorAll<HTMLAnchorElement>('.nav-link'));
		spyObserver = new IntersectionObserver(
			(entries) => {
				entries.forEach((e) => {
					if (e.isIntersecting) {
						navLinkEls.forEach((l) => {
							const isActive = l.getAttribute('href') === '#' + e.target.id;
							l.classList.toggle('active', isActive);
							if (isActive) l.setAttribute('aria-current', 'page');
							else l.removeAttribute('aria-current');
						});
					}
				});
			},
			{ rootMargin: '-45% 0px -50% 0px', threshold: 0 }
		);
		sections.forEach((s) => spyObserver!.observe(s));
	}

	document.addEventListener('astro:before-swap', () => {
		spyObserver?.disconnect();
		spyObserver = null;
	});
	document.addEventListener('astro:page-load', initScrollspy);
</script>
