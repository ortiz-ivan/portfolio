---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
}

const {
	title = 'Iván Ortiz | Fullstack Developer',
	description = 'Portfolio de Iván Ortiz, enfocado en sistemas de gestión y automatización de procesos para negocios reales.',
	ogImage = '/og-image.png'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href="/favicon-round.png" />
		<link rel="canonical" href={canonicalURL} />

		<!-- Fuentes editoriales -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,300;0,6..72,400;0,6..72,500;1,6..72,300;1,6..72,400&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
		/>

		<!-- Meta base -->
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#100f0d" />
		<meta name="robots" content="index, follow" />

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:image:alt" content="Iván Ortiz — Fullstack Developer" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:locale" content="es_PY" />

		<!-- Twitter / X -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL} />

		<title>{title}</title>

		<!-- Datos estructurados -->
		<script type="application/ld+json" set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@graph': [
				{
					'@type': 'Person',
					'@id': `${Astro.site}#person`,
					name: 'Iván Ortiz',
					jobTitle: 'Fullstack Developer',
					url: Astro.site,
					sameAs: [
						'https://www.linkedin.com/in/ortiz-ivan08/',
						'https://github.com/ortiz-ivan'
					],
					description: 'Desarrollador fullstack enfocado en sistemas de gestión, automatización e integraciones para operaciones reales.'
				},
				{
					'@type': 'WebSite',
					'@id': `${Astro.site}#website`,
					url: Astro.site,
					name: 'Iván Ortiz | Fullstack Developer',
					author: { '@id': `${Astro.site}#person` }
				}
			]
		})} />

		<ClientRouter />
	</head>
	<body>
		<a class="skip-nav" href="#top">Saltar al contenido</a>
		<slot />
		<script>
			let revealObserver: IntersectionObserver | null = null;

			function initReveal() {
				const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				const els = Array.from(document.querySelectorAll<HTMLElement>('.reveal:not(.in)'));
				if (reduce) { els.forEach((el) => el.classList.add('in')); return; }

				const STAGGER = 70;
				const DURATION = 750;

				revealObserver = new IntersectionObserver(
					(entries) => {
						const batch = entries
							.filter((e) => e.isIntersecting)
							.map((e) => e.target as HTMLElement)
							.sort((a, b) =>
								a.compareDocumentPosition(b) & Node.DOCUMENT_POSITION_FOLLOWING ? -1 : 1
							);

						batch.forEach((el, i) => {
							const delay = i * STAGGER;
							el.style.transitionDelay = `${delay}ms`;
							el.classList.add('in');
							revealObserver!.unobserve(el);
							if (delay > 0) {
								setTimeout(() => { el.style.transitionDelay = ''; }, delay + DURATION);
							}
						});
					},
					{ rootMargin: '0px 0px -8% 0px', threshold: 0.06 }
				);

				els.forEach((el) => revealObserver!.observe(el));
			}

			document.addEventListener('astro:before-swap', () => {
				revealObserver?.disconnect();
				revealObserver = null;
			});
			document.addEventListener('astro:page-load', initReveal);
		</script>
	</body>
</html>
