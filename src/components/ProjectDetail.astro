---
import type { CollectionEntry } from 'astro:content';
import NavBar from './NavBar.astro';
import CaseStudyHero from './CaseStudyHero.astro';
import CaseStudyContent from './CaseStudyContent.astro';
import '../styles/editorial-home.css';
import '../styles/editorial-project.css';

interface Props {
	project: CollectionEntry<'projects'>['data'];
	slug: string;
}

const { project, slug } = Astro.props;

const projNavItems = [
	{ href: '/#projects', label: 'Proyectos', index: '←' },
	{ href: '/#contact', label: 'Contacto' }
];
---

<main class="ed-home" id="top">
	<NavBar name="Iván Ortiz" brandHref="/" items={projNavItems} />
	<CaseStudyHero project={project} slug={slug} />
	<CaseStudyContent project={project} />
</main>
