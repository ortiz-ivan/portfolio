---
import type { CollectionEntry } from 'astro:content';
import NavBar from './NavBar.astro';
import '../styles/editorial-home.css';
import '../styles/editorial-project.css';

function buildSrcset(src: string): string {
	const dot = src.lastIndexOf('.');
	if (dot < 0) return src;
	const base = src.slice(0, dot);
	const ext = src.slice(dot);
	return `${base}-640${ext} 640w, ${src} 924w`;
}

interface Props {
	project: CollectionEntry<'projects'>['data'];
	slug: string;
}

const { project, slug } = Astro.props;

type ProjectData  = CollectionEntry<'projects'>['data'];
type ProjectImage = ProjectData['images'][number];
type ProjectLink  = ProjectData['links'][number];
type ArchLayer    = ProjectData['caseStudy']['architecture']['layers'][number];
type ReadyImage   = ProjectImage & { src: string };

const readyImages = project.images.filter(
	(img: ProjectImage): img is ReadyImage => img.status === 'ready' && !!img.src
);

const projNavItems = [
	{ href: '/#projects', label: 'Proyectos', index: '←' },
	{ href: '/#contact', label: 'Contacto' }
];

const year = new Date().getFullYear();
---

<main class="ed-home" id="top">
	<NavBar name="Iván Ortiz" brandHref="/" items={projNavItems} />

	<!-- ============ HERO ============ -->
	<section class="ed-hero">
		<div class="wrap">
			<div class="hero-top reveal">
				<span class="ed-eyebrow"><span class="dot"></span>{project.eyebrow}</span>
				<a class="tlink" href="/#projects">← Todos los proyectos <span class="arrow">↗</span></a>
			</div>

			{readyImages.length > 0 ? (
				<>
					<div class="cs-proj-hero-grid">
						<div class="cs-hero-left reveal">
							<h1 class="hero-title display" transition:name={`proj-name-${slug}`}>
								<span class="line">{project.name}</span>
							</h1>
							<p class="hero-intro">{project.summary}</p>
							<div class="hero-narr-wrap">
								<p class="hero-narrative">{project.longDescription}</p>
							</div>
							<div class="cta-row">
								{project.links.filter((l: ProjectLink) => l.kind !== 'case-study').map((l: ProjectLink) =>
									l.kind === 'github-private' ? (
										<a class="btn btn-ghost" href={l.href}>
											{l.label} <span class="arrow">↗</span>
										</a>
									) : l.available ? (
										<a
											class="btn"
											href={l.href}
											target={l.href.startsWith('http') ? '_blank' : undefined}
											rel={l.href.startsWith('http') ? 'noopener' : undefined}
										>
											{l.label} <span class="arrow">↗</span>
										</a>
									) : (
										<span class="btn btn-ghost" style="opacity:0.4;cursor:default">
											{l.label} · pronto
										</span>
									)
								)}
							</div>
						</div>

						<figure class="cs-carousel reveal">
							<div class="cs-carousel-viewport">
								<div class="cs-carousel-track" id="cs-track">
									{readyImages.map((img: ReadyImage, i: number) => (
										<div class="cs-carousel-slide" data-caption={img.caption}>
											<div class="cs-screenshot-frame">
												<img
													src={img.src}
													srcset={buildSrcset(img.src)}
													sizes="(max-width: 920px) calc(100vw - 2.5rem), min(54vw, 680px)"
													alt={img.alt}
													loading={i === 0 ? "eager" : "lazy"}
													width="924"
													height="540"
												/>
											</div>
										</div>
									))}
								</div>
							</div>
							<div class="cs-carousel-footer">
								<figcaption class="cs-screenshot-caption" id="cs-caption">
									{readyImages[0].caption}
								</figcaption>
								{readyImages.length > 1 && (
									<div class="cs-carousel-controls">
										<button class="cs-carousel-btn" id="cs-prev" aria-label="Anterior">←</button>
										<span class="cs-carousel-counter" id="cs-counter">1 / {readyImages.length}</span>
										<button class="cs-carousel-btn" id="cs-next" aria-label="Siguiente">→</button>
									</div>
								)}
							</div>
						</figure>
					</div>

					<div class="cs-proj-hero-meta reveal">
						<div class="meta-row">
							<span class="meta-k">Propósito</span>
							<span class="meta-v">{project.highlight}</span>
						</div>
						<div class="meta-row">
							<span class="meta-k">Resultado clave</span>
							<span class="meta-v">{project.results[0]}</span>
						</div>
						<div class="meta-row">
							<span class="meta-k">Stack</span>
							<div class="tag-row">
								{project.tech.map((t: string) => <span class="tag">{t}</span>)}
							</div>
						</div>
					</div>
				</>
			) : (
				<>
					<h1 class="hero-title display reveal" transition:name={`proj-name-${slug}`}>
						<span class="line">{project.name}</span>
					</h1>

					<div class="ed-hero-grid">
						<div class="ed-hero-copy reveal">
							<p class="hero-intro">{project.summary}</p>
							<div class="hero-narr-wrap">
								<p class="hero-narrative">{project.longDescription}</p>
							</div>
							<div class="cta-row">
								{project.links.filter((l: ProjectLink) => l.kind !== 'case-study').map((l: ProjectLink) =>
									l.kind === 'github-private' ? (
										<a class="btn btn-ghost" href={l.href}>
											{l.label} <span class="arrow">↗</span>
										</a>
									) : l.available ? (
										<a
											class="btn"
											href={l.href}
											target={l.href.startsWith('http') ? '_blank' : undefined}
											rel={l.href.startsWith('http') ? 'noopener' : undefined}
										>
											{l.label} <span class="arrow">↗</span>
										</a>
									) : (
										<span class="btn btn-ghost" style="opacity:0.4;cursor:default">
											{l.label} · pronto
										</span>
									)
								)}
							</div>
						</div>

						<aside class="hero-meta reveal">
							<div class="meta-row">
								<span class="meta-k">Propósito</span>
								<span class="meta-v">{project.highlight}</span>
							</div>
							<div class="meta-row">
								<span class="meta-k">Resultado clave</span>
								<span class="meta-v">{project.results[0]}</span>
							</div>
							<div class="meta-row">
								<span class="meta-k">Stack</span>
								<div class="tag-row">
									{project.tech.map((t: string) => <span class="tag">{t}</span>)}
								</div>
							</div>
						</aside>
					</div>
				</>
			)}
		</div>
	</section>

	<!-- ============ 01 — PROBLEMA ============ -->
	<section class="ed-section">
		<div class="wrap">
			<div class="sec-head reveal">
				<span class="sec-num">(01)</span>
				<span class="sec-label">Problema</span>
				<span class="rule-flex"></span>
			</div>
			<div class="cs-split reveal">
				<div class="cs-split-head">
					<h2 class="cs-split-title">{project.caseStudy.problem.title}</h2>
				</div>
				<div class="cs-split-body">
					<p class="hero-narrative">{project.caseStudy.problem.description}</p>
					<ol class="exp-resp">
						{project.caseStudy.problem.points.map((p: string) => <li>{p}</li>)}
					</ol>
				</div>
			</div>
		</div>
	</section>

	<!-- ============ 02 — SOLUCIÓN ============ -->
	<section class="ed-section">
		<div class="wrap">
			<div class="sec-head reveal">
				<span class="sec-num">(02)</span>
				<span class="sec-label">Solución</span>
				<span class="rule-flex"></span>
			</div>
			<div class="cs-split reveal">
				<div class="cs-split-head">
					<h2 class="cs-split-title">{project.caseStudy.solution.title}</h2>
				</div>
				<div class="cs-split-body">
					<p class="hero-narrative">{project.caseStudy.solution.description}</p>
					<ol class="exp-resp">
						{project.caseStudy.solution.points.map((p: string) => <li>{p}</li>)}
					</ol>
				</div>
			</div>
		</div>
	</section>


	<!-- ============ 03 — ARQUITECTURA ============ -->
	<section class="ed-section">
		<div class="wrap">
			<div class="sec-head reveal">
				<span class="sec-num">(03)</span>
				<span class="sec-label">Arquitectura</span>
				<span class="rule-flex"></span>
			</div>
			<div class="cs-arch-intro reveal">
				<h2 class="cs-arch-title">{project.caseStudy.architecture.title}</h2>
				<p class="cs-arch-text">{project.caseStudy.architecture.description}</p>
			</div>
			<div class="cs-layers">
				{project.caseStudy.architecture.layers.map((layer: ArchLayer) => (
					<div class="cs-layer reveal">
						<span class="cs-layer-name">{layer.name}</span>
						<p class="cs-layer-desc">{layer.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ============ 04 — STACK Y DECISIONES ============ -->
	<section class="ed-section">
		<div class="wrap">
			<div class="sec-head reveal">
				<span class="sec-num">(04)</span>
				<span class="sec-label">Stack y decisiones</span>
				<span class="rule-flex"></span>
			</div>
			<div class="cs-tech-grid reveal">
				<div>
					<p class="hero-narrative">{project.caseStudy.technologiesNote}</p>
					<div class="tag-row" style="margin-top: 1.8rem;">
						{project.tech.map((t: string) => <span class="tag">{t}</span>)}
					</div>
				</div>
				<div>
					<ol class="exp-resp">
						{project.technicalDecisions.map((d: string) => <li>{d}</li>)}
					</ol>
				</div>
			</div>
		</div>
	</section>

	<!-- ============ 05 — RESULTADOS ============ -->
	<section class="ed-section">
		<div class="wrap">
			<div class="sec-head reveal">
				<span class="sec-num">(05)</span>
				<span class="sec-label">Resultados</span>
				<span class="rule-flex"></span>
			</div>
			<div class="cs-results">
				{project.results.map((r: string, i: number) => (
					<div class="cs-result reveal">
						<span class="cs-result-num">{String(i + 1).padStart(2, '0')}</span>
						<p class="cs-result-text">{r}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ============ CONTACTO / CTA ============ -->
	<section class="contact">
		<div class="wrap">
			<div class="sec-head reveal">
				<span class="sec-num">(06)</span>
				<span class="sec-label">Siguiente paso</span>
				<span class="rule-flex"></span>
			</div>

			<h2 class="contact-head display reveal">
				¿Hablamos sobre una oportunidad similar?
			</h2>

			<div class="cta-row reveal">
				<a class="btn" href="/">Inicio <span class="arrow">↗</span></a>
				<a class="btn btn-ghost" href="/#contact">Contactar <span class="arrow">↗</span></a>
			</div>

			<footer class="footer">
				<p class="footer-copy">Diseñado y construido con criterio técnico por Iván Ortiz.</p>
				<div class="footer-meta">
					<a class="footer-top" href="#top">Volver arriba <span class="arrow">↑</span></a>
					<div class="footer-year">© {year} · Iván Ortiz</div>
				</div>
			</footer>
		</div>
	</section>
</main>

<script>
	function initCaseStudyCarousel() {
		const track = document.getElementById('cs-track') as HTMLElement | null;
		const captionEl = document.getElementById('cs-caption');
		const counterEl = document.getElementById('cs-counter');
		const prevBtn = document.getElementById('cs-prev');
		const nextBtn = document.getElementById('cs-next');

		if (!track) return;

		const slides = Array.from(track.querySelectorAll<HTMLElement>('.cs-carousel-slide'));
		const total = slides.length;
		let current = 0;

		function goTo(index: number) {
			current = ((index % total) + total) % total;
			track!.style.transform = `translateX(-${current * 100}%)`;
			if (captionEl) captionEl.textContent = slides[current].dataset.caption ?? '';
			if (counterEl) counterEl.textContent = `${current + 1} / ${total}`;
		}

		prevBtn?.addEventListener('click', () => goTo(current - 1));
		nextBtn?.addEventListener('click', () => goTo(current + 1));
	}

	document.addEventListener('astro:page-load', initCaseStudyCarousel);
</script>
