---
import type { CollectionEntry } from 'astro:content';
import NavBar from './NavBar.astro';
import '../styles/editorial-home.css';
import '../styles/editorial-project.css';

interface Props {
	project: CollectionEntry<'projects'>['data'];
	slug: string;
}

const { project, slug } = Astro.props;

const readyImages = project.images.filter(
	(img): img is typeof img & { src: string } => img.status === 'ready' && !!img.src
);

const projNavItems = [
	{ href: '/#projects', label: 'Proyectos', index: '←' },
	{ href: '/#contact', label: 'Contacto' }
];

const year = new Date().getFullYear();
---

<main class="ed-home" id="top">
	<NavBar name="Iván Ortiz" brandHref="/" items={projNavItems} />

	<!-- ============ HERO ============ -->
	<section class="ed-hero">
		<div class="wrap">
			<div class="hero-top reveal">
				<span class="ed-eyebrow"><span class="dot"></span>{project.eyebrow}</span>
				<a class="tlink" href="/#projects">← Todos los proyectos <span class="arrow">↗</span></a>
			</div>

			{readyImages.length > 0 ? (
				<>
					<div class="cs-proj-hero-grid">
						<div class="cs-hero-left reveal">
							<h1 class="hero-title display" transition:name={`proj-name-${slug}`}>
								<span class="line">{project.name}</span>
							</h1>
							<p class="hero-intro">{project.summary}</p>
							<div class="hero-narr-wrap">
								<p class="hero-narrative">{project.longDescription}</p>
							</div>
							<div class="cta-row">
								{project.links.map((l) =>
									l.available ? (
										<a
											class="btn"
											href={l.href}
											target={l.href.startsWith('http') ? '_blank' : undefined}
											rel={l.href.startsWith('http') ? 'noopener' : undefined}
										>
											{l.label} <span class="arrow">↗</span>
										</a>
									) : (
										<span class="btn btn-ghost" style="opacity:0.4;cursor:default">
											{l.label} · pronto
										</span>
									)
								)}
							</div>
						</div>

						<figure class="cs-hero-visual reveal">
							<div class="cs-screenshot-frame">
								<img
									src={readyImages[0].src}
									alt={readyImages[0].alt}
									loading="eager"
									width="800"
									height="600"
								/>
							</div>
							<figcaption class="cs-screenshot-caption">{readyImages[0].caption}</figcaption>
						</figure>
					</div>

					<div class="cs-proj-hero-meta reveal">
						<div class="meta-row">
							<span class="meta-k">Propósito</span>
							<span class="meta-v">{project.highlight}</span>
						</div>
						<div class="meta-row">
							<span class="meta-k">Resultado clave</span>
							<span class="meta-v">{project.results[0]}</span>
						</div>
						<div class="meta-row">
							<span class="meta-k">Stack</span>
							<div class="tag-row">
								{project.tech.map((t) => <span class="tag">{t}</span>)}
							</div>
						</div>
					</div>
				</>
			) : (
				<>
					<h1 class="hero-title display reveal" transition:name={`proj-name-${slug}`}>
						<span class="line">{project.name}</span>
					</h1>

					<div class="ed-hero-grid">
						<div class="ed-hero-copy reveal">
							<p class="hero-intro">{project.summary}</p>
							<div class="hero-narr-wrap">
								<p class="hero-narrative">{project.longDescription}</p>
							</div>
							<div class="cta-row">
								{project.links.map((l) =>
									l.available ? (
										<a
											class="btn"
											href={l.href}
											target={l.href.startsWith('http') ? '_blank' : undefined}
											rel={l.href.startsWith('http') ? 'noopener' : undefined}
										>
											{l.label} <span class="arrow">↗</span>
										</a>
									) : (
										<span class="btn btn-ghost" style="opacity:0.4;cursor:default">
											{l.label} · pronto
										</span>
									)
								)}
							</div>
						</div>

						<aside class="hero-meta reveal">
							<div class="meta-row">
								<span class="meta-k">Propósito</span>
								<span class="meta-v">{project.highlight}</span>
							</div>
							<div class="meta-row">
								<span class="meta-k">Resultado clave</span>
								<span class="meta-v">{project.results[0]}</span>
							</div>
							<div class="meta-row">
								<span class="meta-k">Stack</span>
								<div class="tag-row">
									{project.tech.map((t) => <span class="tag">{t}</span>)}
								</div>
							</div>
						</aside>
					</div>
				</>
			)}
		</div>
	</section>

	<!-- ============ 01 — PROBLEMA ============ -->
	<section class="ed-section">
		<div class="wrap">
			<div class="sec-head reveal">
				<span class="sec-num">(01)</span>
				<span class="sec-label">Problema</span>
				<span class="rule-flex"></span>
			</div>
			<div class="cs-split reveal">
				<div class="cs-split-head">
					<h2 class="cs-split-title">{project.caseStudy.problem.title}</h2>
				</div>
				<div class="cs-split-body">
					<p class="hero-narrative">{project.caseStudy.problem.description}</p>
					<ol class="exp-resp">
						{project.caseStudy.problem.points.map((p) => <li>{p}</li>)}
					</ol>
				</div>
			</div>
		</div>
	</section>

	<!-- ============ 02 — SOLUCIÓN ============ -->
	<section class="ed-section">
		<div class="wrap">
			<div class="sec-head reveal">
				<span class="sec-num">(02)</span>
				<span class="sec-label">Solución</span>
				<span class="rule-flex"></span>
			</div>
			<div class="cs-split reveal">
				<div class="cs-split-head">
					<h2 class="cs-split-title">{project.caseStudy.solution.title}</h2>
				</div>
				<div class="cs-split-body">
					<p class="hero-narrative">{project.caseStudy.solution.description}</p>
					<ol class="exp-resp">
						{project.caseStudy.solution.points.map((p) => <li>{p}</li>)}
					</ol>
				</div>
			</div>
		</div>
	</section>

	<!-- ============ SCREENSHOTS (imágenes adicionales, no la del hero) ============ -->
	{readyImages.length > 1 && (
		<section class="cs-screenshots">
			<div class="wrap">
				{readyImages.slice(1).map((img) => (
					<figure class="cs-screenshot reveal">
						<div class="cs-screenshot-frame">
							<img
								src={img.src}
								alt={img.alt}
								loading="lazy"
								width="800"
								height="600"
							/>
						</div>
						<figcaption class="cs-screenshot-caption">{img.caption}</figcaption>
					</figure>
				))}
			</div>
		</section>
	)}

	<!-- ============ 03 — ARQUITECTURA ============ -->
	<section class="ed-section">
		<div class="wrap">
			<div class="sec-head reveal">
				<span class="sec-num">(03)</span>
				<span class="sec-label">Arquitectura</span>
				<span class="rule-flex"></span>
			</div>
			<div class="cs-arch-intro reveal">
				<h2 class="cs-arch-title">{project.caseStudy.architecture.title}</h2>
				<p class="cs-arch-text">{project.caseStudy.architecture.description}</p>
			</div>
			<div class="cs-layers">
				{project.caseStudy.architecture.layers.map((layer) => (
					<div class="cs-layer reveal">
						<span class="cs-layer-name">{layer.name}</span>
						<p class="cs-layer-desc">{layer.description}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ============ 04 — STACK Y DECISIONES ============ -->
	<section class="ed-section">
		<div class="wrap">
			<div class="sec-head reveal">
				<span class="sec-num">(04)</span>
				<span class="sec-label">Stack y decisiones</span>
				<span class="rule-flex"></span>
			</div>
			<div class="cs-tech-grid reveal">
				<div>
					<p class="hero-narrative">{project.caseStudy.technologiesNote}</p>
					<div class="tag-row" style="margin-top: 1.8rem;">
						{project.tech.map((t) => <span class="tag">{t}</span>)}
					</div>
				</div>
				<div>
					<ol class="exp-resp">
						{project.technicalDecisions.map((d) => <li>{d}</li>)}
					</ol>
				</div>
			</div>
		</div>
	</section>

	<!-- ============ 05 — RESULTADOS ============ -->
	<section class="ed-section">
		<div class="wrap">
			<div class="sec-head reveal">
				<span class="sec-num">(05)</span>
				<span class="sec-label">Resultados</span>
				<span class="rule-flex"></span>
			</div>
			<div class="cs-results">
				{project.results.map((r, i) => (
					<div class="cs-result reveal">
						<span class="cs-result-num">{String(i + 1).padStart(2, '0')}</span>
						<p class="cs-result-text">{r}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- ============ CONTACTO / CTA ============ -->
	<section class="contact">
		<div class="wrap">
			<div class="sec-head reveal">
				<span class="sec-num">(06)</span>
				<span class="sec-label">Siguiente paso</span>
				<span class="rule-flex"></span>
			</div>

			<h2 class="contact-head display reveal">
				¿Hablamos sobre una oportunidad similar?
			</h2>

			<div class="cta-row reveal">
				<a class="btn" href="/">Inicio <span class="arrow">↗</span></a>
				<a class="btn btn-ghost" href="/#contact">Contactar <span class="arrow">↗</span></a>
			</div>

			<footer class="footer">
				<p class="footer-copy">Diseñado y construido con criterio técnico por Iván Ortiz.</p>
				<div class="footer-meta">
					<a class="footer-top" href="#top">Volver arriba <span class="arrow">↑</span></a>
					<div class="footer-year">© {year} · Iván Ortiz</div>
				</div>
			</footer>
		</div>
	</section>
</main>
