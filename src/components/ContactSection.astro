---
import type { ContactSection, FooterContent } from '../data/site';

interface Props {
	data: ContactSection;
	footer: FooterContent;
	authorName: string;
}

const { data, footer, authorName } = Astro.props;
const year = new Date().getFullYear();
const w3fKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? '';
---

<section class="contact" id="contact">
	<div class="wrap">
		<div class="sec-head reveal">
			<span class="sec-num">(05)</span>
			<span class="sec-label">Contacto</span>
			<span class="rule-flex"></span>
		</div>

		<div class="contact-layout">
			<!-- Columna izquierda: intro + form + éxito -->
			<div class="contact-form-col">
				<p class="contact-intro reveal">
					¿Tenés una propuesta, pregunta o simplemente querés hablar de software? Escribime
					directamente.
				</p>
				<form
					class="contact-form reveal"
					id="contactForm"
					method="POST"
					action="https://api.web3forms.com/submit"
				>
					<input type="hidden" name="access_key" value={w3fKey} />
					<input type="hidden" name="subject" value="Nuevo mensaje desde el portfolio" />
					<input type="hidden" name="from_name" value="Portfolio Contact" />
					<input
						type="checkbox"
						name="botcheck"
						class="form-honeypot"
						tabindex="-1"
						autocomplete="off"
					/>

					<div class="form-row">
						<div class="form-field">
							<label class="form-label" for="f-name">Nombre</label>
							<input
								class="form-input"
								type="text"
								id="f-name"
								name="name"
								required
								placeholder="Tu nombre"
								autocomplete="name"
							/>
						</div>
						<div class="form-field">
							<label class="form-label" for="f-email">Email</label>
							<input
								class="form-input"
								type="email"
								id="f-email"
								name="email"
								required
								placeholder="tu@email.com"
								autocomplete="email"
							/>
						</div>
					</div>

					<div class="form-field">
						<label class="form-label" for="f-message">Mensaje</label>
						<textarea
							class="form-input form-textarea"
							id="f-message"
							name="message"
							required
							rows="5"
							placeholder="¿En qué puedo ayudarte?"></textarea>
					</div>

					<div class="form-actions">
						<button class="btn" type="submit" id="formSubmit">
							Enviar mensaje <span class="arrow" aria-hidden="true">↗︎</span>
						</button>
						<p class="form-error" id="formError" role="alert" aria-live="polite"></p>
					</div>
				</form>

				<div class="form-success" id="formSuccess" hidden aria-live="polite">
					<span class="form-success-mark" aria-hidden="true">✓</span>
					<div>
						<p class="form-success-title">Mensaje enviado.</p>
						<p class="form-success-desc">
							Te respondo a la brevedad. Mientras tanto, también me encontrás en LinkedIn o GitHub.
						</p>
					</div>
				</div>
			</div>

			<!-- Columna derecha: links -->
			<aside class="contact-links reveal">
				<p class="contact-links-label">Encontrame en</p>
				{
					data.items.map((item) => {
						const external = item.href.startsWith('http');
						return (
							<div class="ed-contact-item">
								<span class="contact-k">{item.label}</span>
								<a
									class="contact-v"
									href={item.href}
									target={external ? '_blank' : undefined}
									rel={external ? 'noopener noreferrer' : undefined}
								>
									{item.value} <span class="arrow">↗︎</span>
								</a>
								<span class="contact-desc">{item.description}</span>
							</div>
						);
					})
				}
			</aside>
		</div>

		<footer class="footer">
			<p class="footer-copy">{footer.copy}</p>
			<div class="footer-meta">
				<a class="footer-top" href="#top">Volver arriba <span class="arrow">↑︎</span></a>
				<div class="footer-year">© {year} · Diseñado y construido por {authorName}</div>
			</div>
		</footer>
	</div>
</section>

<script>
	function initContactForm() {
		const form = document.getElementById('contactForm') as HTMLFormElement | null;
		const submitBtn = document.getElementById('formSubmit') as HTMLButtonElement | null;
		const errorEl = document.getElementById('formError');
		const successEl = document.getElementById('formSuccess');
		if (!form || !submitBtn || !errorEl || !successEl) return;

		const btnTextNode = submitBtn.firstChild as Text;

		form.addEventListener('submit', async (e) => {
			e.preventDefault();
			submitBtn.disabled = true;
			submitBtn.setAttribute('aria-disabled', 'true');
			submitBtn.classList.add('is-loading');
			form.setAttribute('aria-busy', 'true');
			btnTextNode.nodeValue = 'Enviando… ';
			errorEl.textContent = '';

			try {
				const res = await fetch('https://api.web3forms.com/submit', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
					body: JSON.stringify(Object.fromEntries(new FormData(form)))
				});
				const json = await res.json();
				if (!json.success) throw new Error(json.message ?? 'Error');
				form.hidden = true;
				successEl.hidden = false;
			} catch {
				errorEl.textContent =
					'Algo salió mal. Intentá de nuevo o escribime directamente por email.';
				submitBtn.disabled = false;
				submitBtn.removeAttribute('aria-disabled');
				submitBtn.classList.remove('is-loading');
				form.removeAttribute('aria-busy');
				btnTextNode.nodeValue = 'Enviar mensaje ';
			}
		});
	}

	document.addEventListener('astro:page-load', initContactForm);
</script>
